# ==== Telegram core credentials (required) ====
# Get API_ID and API_HASH from https://my.telegram.org -> API development tools
API_ID=1234567
API_HASH=your_api_hash_here

# Bot token from @BotFather
BOT_TOKEN=123456:ABC-your-bot-token

# Your Telegram numeric user id (the super owner, cannot be removed as admin)
OWNER_ID=123456789

# ==== Large-file delivery (needed for files > 50 MB, up to ~2 GB) ====
# Set LOG_CHANNEL to enable it. On the FIRST run, `python bot.py` will ask for
# your phone number + login code once, then save a session file and reuse it.
# BOTH your user account AND the bot must be members/admins of this channel.
# Channel ids look like -1001234567890
LOG_CHANNEL=

# Optional: paste a saved user session string to skip the phone-number login
# (useful for servers). Leave empty to use the interactive file-session login.
SESSION_STRING=

# ==== Extraction APIs ====
VIDBUNKER_API=https://vidbunker-backend.dailyweb577.workers.dev/api/download

# TeraBox via xAPIverse. Keys are managed in the admin panel (/addkey), but you
# can seed one or more (comma-separated) here for the first run:
TERABOX_API_URL=https://xapiverse.com/api/terabox-pro
TERABOX_API_KEYS=

# ==== Speed / delivery ====
# Parallel connections for the ultra-fast userbot upload (0/1 disables it)
FAST_UPLOAD_CONNECTIONS=8

# Default delivery mode (also changeable live via /setmode):
#   auto     -> small files to Telegram, big files as a direct link (asks for mid-size)
#   link     -> always send a direct download link (no upload)
#   telegram -> always upload to Telegram (link if over the limit)
DELIVERY_MODE=auto

# Direct-link URL shortener (best effort; falls back to the raw link)
ENABLE_SHORTENER=true
SHORTENER_SERVICE=tinyurl            # tinyurl | isgd

# Concurrency for the lightweight resolve/link path (near-instant work).
# The heavy download+upload path is bounded by MAX_CONCURRENT below.
MAX_LINK_CONCURRENT=1000

# ==== Auto-delete (also changeable live via the admin panel) ====
# Seconds after which delivered VIDEOS are removed. 0 = keep videos forever.
AUTO_DELETE_VIDEOS=0
# Seconds after which status/notification/link messages are removed.
NOTIFY_DELETE=10

# ==== Optional proxy (use if your network blocks/throttles Telegram) ====
# Examples: socks5://127.0.0.1:9050  or  socks5://user:pass@host:1080
PROXY=

# ==== Limits & behaviour (optional, sensible defaults shown) ====
# Downloads per day for normal users (admins are unlimited). Live-editable via /setlimit
DEFAULT_DAILY_LIMIT=10
# Per-file size cap for normal users, in MB (admins have no cap beyond Telegram's limit)
USER_MAX_FILE_SIZE_MB=1024
# Telegram upload cap in MB: 2048 for a normal account, 4096 if the USER account
# has Telegram Premium. Files bigger than this cannot be delivered.
TELEGRAM_MAX_SIZE_MB=2048
# How many downloads run at the same time across all users (you have 64GB RAM -> can raise)
MAX_CONCURRENT=4
# Retry counts
API_RETRIES=4
DOWNLOAD_RETRIES=3

# ==== Paths ====
DOWNLOAD_DIR=venev
DB_PATH=vidbot.db
# User-account session file (created automatically on first phone-number login).
# On a VPS, prefer SESSION_STRING above instead of copying this file — .session
# files are NOT portable across machines/Telethon versions.
USER_SESSION=sessions/user_account
